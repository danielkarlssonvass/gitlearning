<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Screen flow launched from an Opportunity record page. Displays the current Close Date and lets the user update it. If the date is changed, the record is updated and a success screen confirms the new Close Date.</description>
    <interviewLabel>Opportunity Update Close Date {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opportunity Update Close Date</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <runInMode>DefaultMode</runInMode>
    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Opportunity</targetReference>
        </connector>
    </start>
    <status>Active</status>

    <!-- ═══════════════════════════════════════
         VARIABLES
    ═══════════════════════════════════════ -->

    <!-- Passed in automatically when the flow is launched from a record page -->
    <variables>
        <name>recordId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>

    <!-- ═══════════════════════════════════════
         GET RECORDS
    ═══════════════════════════════════════ -->

    <recordLookups>
        <name>Get_Opportunity</name>
        <label>Get Opportunity</label>
        <locationX>176</locationX>
        <locationY>120</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Screen_UpdateCloseDate</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Opportunity</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>

    <!-- ═══════════════════════════════════════
         SCREENS
    ═══════════════════════════════════════ -->

    <!-- Screen 1: Show current Close Date and let user update it -->
    <screens>
        <name>Screen_UpdateCloseDate</name>
        <label>Update Close Date</label>
        <locationX>176</locationX>
        <locationY>240</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Decision_DateChanged</targetReference>
        </connector>
        <fields>
            <name>Display_OpportunityName</name>
            <fieldText>&lt;p&gt;&lt;b&gt;Opportunity:&lt;/b&gt; {!Get_Opportunity.Name}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>Input_CloseDate</name>
            <dataType>Date</dataType>
            <defaultValue>
                <elementReference>Get_Opportunity.CloseDate</elementReference>
            </defaultValue>
            <fieldText>Close Date</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <!-- Screen 2: Success — shown after a successful update -->
    <screens>
        <name>Screen_Success</name>
        <label>Success</label>
        <locationX>88</locationX>
        <locationY>600</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>Display_SuccessMessage</name>
            <fieldText>&lt;p&gt;&lt;b&gt;Close Date updated successfully.&lt;/b&gt;&lt;/p&gt;&lt;p&gt;New Close Date: &lt;b&gt;{!Input_CloseDate}&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <!-- Screen 3: No change — shown when user submits without modifying the date -->
    <screens>
        <name>Screen_NoChange</name>
        <label>No Changes Made</label>
        <locationX>264</locationX>
        <locationY>600</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>Display_NoChangeMessage</name>
            <fieldText>&lt;p&gt;No changes were made. The Close Date remains &lt;b&gt;{!Get_Opportunity.CloseDate}&lt;/b&gt;.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>

    <!-- ═══════════════════════════════════════
         DECISIONS
    ═══════════════════════════════════════ -->

    <decisions>
        <name>Decision_DateChanged</name>
        <label>Date Changed?</label>
        <locationX>176</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>Screen_NoChange</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Change</defaultConnectorLabel>
        <rules>
            <name>Outcome_DateWasChanged</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Input_CloseDate</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>Get_Opportunity.CloseDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Opportunity</targetReference>
            </connector>
            <label>Date Was Changed</label>
        </rules>
    </decisions>

    <!-- ═══════════════════════════════════════
         RECORD UPDATES
    ═══════════════════════════════════════ -->

    <recordUpdates>
        <name>Update_Opportunity</name>
        <label>Update Opportunity</label>
        <locationX>88</locationX>
        <locationY>480</locationY>
        <connector>
            <targetReference>Screen_Success</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>CloseDate</field>
            <value>
                <elementReference>Input_CloseDate</elementReference>
            </value>
        </inputAssignments>
        <object>Opportunity</object>
    </recordUpdates>

</Flow>
